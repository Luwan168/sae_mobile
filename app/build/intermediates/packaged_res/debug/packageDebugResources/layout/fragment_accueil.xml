<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/green_surface">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Bienvenue -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/green_primary" android:orientation="vertical" android:padding="20dp">
                <TextView android:id="@+id/tvWelcome" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hello!" android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvRole" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textColor="@color/green_accent" android:textSize="14sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stats rapides -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/tvFormationsCount" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/green_primary" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvBadgesCount" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/green_primary" android:textSize="13sp" android:textStyle="bold"
                        android:gravity="center"/>
                </LinearLayout>
                <TextView android:id="@+id/tvProgressStat" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" android:textColor="@color/text_secondary" android:textSize="13sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bonne pratique du jour -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/lbl_daily_tip" android:textColor="@color/green_primary"
                    android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvTip" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="..." android:textColor="@color/text_primary" android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Proposer un tip -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="12dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/submit_tip_title" android:textColor="@color/green_primary"
                    android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnSubmitTip" android:layout_width="match_parent" android:layout_height="44dp"
                    android:backgroundTint="@color/green_light" android:text="@string/btn_submit_tip"
                    android:textColor="@color/white" android:textSize="13sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
