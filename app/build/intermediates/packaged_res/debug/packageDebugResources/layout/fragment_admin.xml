<?xml version="1.0" encoding="utf-8"?>
<!-- app/src/main/res/layout/fragment_admin.xml -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Statistiques globales -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_stats_title"
                    android:textColor="@color/green_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />
                <TextView android:id="@+id/tvTotalUsers"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="15sp" android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />
                <TextView android:id="@+id/tvTotalFormations"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="15sp" android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />
                <TextView android:id="@+id/tvTotalEnrollments"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="15sp" android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />
                <TextView android:id="@+id/tvGlobalAvgScore"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="15sp" android:textColor="@color/text_primary" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Validation des tips soumis -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pending_tips_title"
                    android:textColor="@color/green_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/btnValidateTips"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="@color/green_primary"
                    android:text="@string/pending_tips_title"
                    android:textColor="@color/white" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Modération tips existants -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_moderation_title"
                    android:textColor="@color/green_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/btnModerBonnesPratiques"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="@color/green_light"
                    android:text="@string/admin_btn_manage_tips"
                    android:textColor="@color/white" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
