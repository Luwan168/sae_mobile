<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="6dp" app:cardCornerRadius="10dp" app:cardElevation="2dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
        <TextView android:id="@+id/tvEnrollTitle"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
        <TextView android:id="@+id/tvEnrollScore"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/green_primary" android:textSize="14sp"
            android:textStyle="bold" android:layout_marginEnd="8dp" android:visibility="gone" />
        <TextView android:id="@+id/tvEnrollStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
