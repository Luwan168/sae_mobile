<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="6dp" app:cardCornerRadius="10dp" app:cardElevation="2dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
        <TextView android:text="★" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/badge_gold" android:textSize="28sp" android:layout_marginEnd="12dp" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvBadgeName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvBadgeFormation"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/green_primary" android:textSize="13sp" android:layout_marginTop="2dp" />
            <TextView android:id="@+id/tvBadgeDate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
