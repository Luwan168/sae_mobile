<?xml version="1.0" encoding="utf-8"?>
<!-- app/src/main/res/layout/item_actualite.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="2dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Ligne principale : logo/vignette + textes ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Vignette gauche : logo par défaut (visible si pas d'image) -->
            <FrameLayout
                android:id="@+id/vignetteLogo"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="12dp">

                <View
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/ic_launcher_background" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_launcher_foreground"
                    android:contentDescription="OpenMinds" />
            </FrameLayout>

            <!-- Contenu texte -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvActualiteTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineSpacingMultiplier="1.15" />

                <TextView
                    android:id="@+id/tvActualiteContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2" />

                <!-- Auteur + Date -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvActualiteAuthor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:visibility="gone" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvActualiteDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Chevron -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription=""
                android:alpha="0.35" />
        </LinearLayout>

        <!-- ── Image complète (visible seulement si image_url présent) ── -->
        <!-- Affichée SOUS le texte, pleine largeur, coins bas arrondis -->
        <ImageView
            android:id="@+id/ivActualiteImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:adjustViewBounds="true" />

        <!-- Ligne accent verte -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/green_accent" />

    </LinearLayout>

</androidx.cardview.widget.CardView>